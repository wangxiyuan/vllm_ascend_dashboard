# Production Environment Configuration for vLLM Ascend Dashboard
# Copy this file to .env.production and customize for your environment
# IMPORTANT: Never commit .env.production to version control!

# =============================================================================
# GitHub Configuration
# =============================================================================
GITHUB_TOKEN=ghp_your_production_github_token_here
GITHUB_OWNER=vllm-project
GITHUB_REPO=vllm-ascend

# =============================================================================
# Database Configuration
# =============================================================================
# For MySQL (recommended for production)
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=vllm_dashboard
MYSQL_USER=dashboard
MYSQL_PASSWORD=your_secure_database_password_here

# For SQLite (simpler setup, uncomment if using SQLite)
# DATABASE_URL=sqlite+aiosqlite:///app/data/app.db

# For MySQL (uncomment if using MySQL)
# DATABASE_URL=mysql+aiomysql://dashboard:your_secure_database_password_here@mysql:3306/vllm_dashboard

# =============================================================================
# JWT Security Configuration
# =============================================================================
# Generate a strong secret key: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Application Configuration
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
TIMEZONE=UTC

# =============================================================================
# Data Synchronization Configuration
# =============================================================================
CI_SYNC_INTERVAL_MINUTES=720
CI_SYNC_DAYS_BACK=7
CI_SYNC_MAX_RUNS_PER_WORKFLOW=100
CI_SYNC_FORCE_FULL_REFRESH=false
DATA_RETENTION_DAYS=365

# =============================================================================
# Frontend Configuration
# =============================================================================
# API base URL - adjust based on your deployment
# For same server: http://localhost:8000/api/v1
# For different server: https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# =============================================================================
# Port Configuration
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
MYSQL_PORT=3306

# =============================================================================
# Optional: SSL/TLS Configuration (if using nginx reverse proxy)
# =============================================================================
# SSL_CERT_PATH=/etc/nginx/certs/your_domain.crt
# SSL_KEY_PATH=/etc/nginx/certs/your_domain.key
