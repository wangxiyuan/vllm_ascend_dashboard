# GitHub 配置
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=vllm-project
GITHUB_REPO=vllm-ascend

# 数据库配置
# 开发环境使用 SQLite
DATABASE_URL=sqlite+aiosqlite:///./app.db

# 生产环境使用 MySQL
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/vllm_dashboard

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# 应用配置
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# 数据同步配置
CI_SYNC_INTERVAL_MINUTES=720  # CI 数据同步间隔（分钟），默认 720 分钟 = 12 小时
CI_SYNC_DAYS_BACK=7  # 自动同步时采集最近 N 天的数据
CI_SYNC_MAX_RUNS_PER_WORKFLOW=100  # 每个 workflow 最多采集多少条记录
CI_SYNC_FORCE_FULL_REFRESH=false  # 是否强制全量覆盖刷新

# 模型同步配置
MODEL_SYNC_INTERVAL_MINUTES=60  # 模型报告同步间隔（分钟），默认 60 分钟
MODEL_SYNC_DAYS_BACK=3  # 自动同步时采集最近 N 天的数据
MODEL_SYNC_RUNS_LIMIT=100  # 每个 workflow 最多获取最近 N 次 runs

DATA_RETENTION_DAYS=365

# 前端刷新配置
FRONTEND_REFRESH_INTERVAL_MINUTES=10  # 前端动态数据刷新间隔（分钟），默认 10 分钟（与 GitHub 缓存过期时间一致）

# GitHub 缓存配置
GITHUB_CACHE_TTL_MINUTES=10  # GitHub API 数据缓存过期时间（分钟），默认 10 分钟

# Project Dashboard 配置
PROJECT_DASHBOARD_CACHE_INTERVAL_MINUTES=60  # Project Dashboard Git 仓库缓存更新间隔（分钟），默认 60 分钟
GITHUB_CACHE_DIR=  # GitHub 本地缓存目录，默认为根目录 data/，留空使用默认值

# 每日总结配置
DAILY_SUMMARY_ENABLED=true  # 是否启用每日总结生成任务
DAILY_SUMMARY_CRON_HOUR=8  # 每日总结生成时间（小时），默认早上 8 点
DAILY_SUMMARY_CRON_MINUTE=0  # 每日总结生成时间（分钟）

# LLM API Keys（用于 AI 总结生成）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 前端 API 地址
VITE_API_BASE_URL=http://localhost:8000/api/v1
